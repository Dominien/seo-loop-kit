# ─────────────────────────────────────────────────────────────────────────────
# Your site. Exactly as it appears in Search Console.
#   Domain property:  sc-domain:example.com
#   URL property:     https://www.example.com/
# ─────────────────────────────────────────────────────────────────────────────
SITE_URL=sc-domain:example.com


# ─────────────────────────────────────────────────────────────────────────────
# Google Search Console — what people actually searched to find you.
#
# 1. console.cloud.google.com -> new project -> enable "Search Console API"
# 2. Credentials -> OAuth client ID -> type "Desktop app"
# 3. Paste the client id + secret below
# 4. Run:  npm run connect     (opens a browser once, writes the refresh token here)
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=


# ─────────────────────────────────────────────────────────────────────────────
# DataForSEO — real search volume, difficulty, and who is on page 1.
#
# Search Console only knows what you ALREADY rank for. It cannot tell you what
# nobody has found yet, or whether a topic has any demand at all. Without this,
# the agent is guessing about every new page it proposes.
#
# Sign up at dataforseo.com. Pay-as-you-go, a few cents per call.
# ─────────────────────────────────────────────────────────────────────────────
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Your market. 2276 = Germany, 2840 = USA, 2826 = UK, 2040 = Austria, 2756 = Switzerland.
# Get this wrong and German keywords come back with volume 0 while your seeds land on
# US search results. Nothing crashes. Everything "works". The results are garbage.
DATAFORSEO_LOCATION_CODE=2276
DATAFORSEO_LANGUAGE_CODE=de


# ─────────────────────────────────────────────────────────────────────────────
# Optional
# ─────────────────────────────────────────────────────────────────────────────
# A keyword below this many searches a month is usually not worth its own page.
VOLUME_FLOOR=40
# Where the board lives. It is committed to git on purpose: that is the memory.
BOARD_PATH=board.jsonl
